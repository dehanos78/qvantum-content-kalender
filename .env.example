# Kopieer dit bestand naar .env en vul je echte token in.
# .env staat in .gitignore en komt nooit in git terecht.
#
# Token aanmaken:
#   HubSpot > Settings (tandwiel) > Integrations > Private Apps > Create a private app
#   Tabblad "Scopes" > zoek op "social" > vink de read-scope aan > Create app
#   Kopieer de Access Token (begint met pat-eu1-... voor EU accounts)

HUBSPOT_TOKEN=pat-eu1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
